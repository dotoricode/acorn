{
  "name": "@dotoricode/acorn",
  "version": "0.4.1",
  "description": "Claude Code harness manager for OMC, gstack, and ECC",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "acorn": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "hooks/guard-check.sh",
    "templates/harness.lock.template.json",
    "scripts/install-shim-windows.sh",
    "docs/USAGE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "build:dev": "tsc",
    "test": "node --test --experimental-strip-types --no-warnings tests/**/*.test.ts",
    "shim:windows": "bash scripts/install-shim-windows.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotoricode/acorn.git"
  },
  "keywords": [
    "claude-code",
    "harness",
    "cli",
    "omc",
    "gstack",
    "everything-claude-code"
  ],
  "author": "dotoricode",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dotoricode/acorn/issues"
  },
  "homepage": "https://github.com/dotoricode/acorn#readme",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}